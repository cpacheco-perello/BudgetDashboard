{
  "name": "dashboardeconomic",
  "version": "1.0.0",
  "description": "Dashboard financiero con gastos e ingresos",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder"
  },
  "dependencies": {
    "body-parser": "^1.20.0",
    "express": "^4.18.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.6.0",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.tuempresa.dashboardeconomic",
    "productName": "DashboardEconomic",
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DashboardEconomic"
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "app.js",
      "public/**/*",
      "finanzas.db",
      "node_modules/express/**/*",
      "node_modules/body-parser/**/*",
      "node_modules/sqlite3/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
