{
  "name": "dashboardeconomic",
  "version": "1.0.0",
  "description": "Dashboard financiero con gastos e ingresos",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder",
    "test": "jest"
  },
  "dependencies": {
    "sqlite3": "^5.1.6",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.tuempresa.dashboardeconomic",
    "productName": "DashboardEconomic",
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DashboardEconomic"
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "src/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/yahoo-finance2/**/*"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**/*.node"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
